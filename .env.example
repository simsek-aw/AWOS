# --- AWOS environment configuration ---
# Copy this file to `.env.local` and fill in real values.
# NEVER commit .env.local — it is gitignored on purpose.

# Supabase project (public, safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY.
# This key BYPASSES Row-Level-Security. It must never reach the browser
# and is only used by trusted server-side code (e.g. the mirroring agent).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent / LLM provider (server only)
ANTHROPIC_API_KEY=your-anthropic-key

# Public base URL of the app (used to build invite-email redirect links).
# Local dev: http://localhost:3000 — in production set your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
