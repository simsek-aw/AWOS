# --- AWOS environment configuration ---
# Copy this file to `.env.local` and fill in real values.
# NEVER commit .env.local — it is gitignored on purpose.

# Supabase project (public, safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY.
# This key BYPASSES Row-Level-Security. It must never reach the browser
# and is only used by trusted server-side code (e.g. the mirroring agent).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent / LLM provider (server only)
ANTHROPIC_API_KEY=your-anthropic-key

# AWideogram (Ideogram 4.0 image generation, server only — mark as Sensitive)
IDEOGRAM_API_KEY=your-ideogram-key
# Optional: max AWideogram images per user per 24h (budget guard; default 100)
# AWIDEOGRAM_DAILY_LIMIT=100

# Error monitoring (optional): if set, server + client errors are POSTed here as
# JSON (wire to Slack / Sentry / a webhook). Unset = log to server console only.
# ERROR_WEBHOOK_URL=https://hooks.example.com/awos-errors

# Single sign-on across AW tools: shared auth-cookie parent domain. Set only in
# production when tools live on subdomains of one domain (leading dot). Leave
# unset for localhost / Vercel preview. Example: .absolutweb.de
# AUTH_COOKIE_DOMAIN=.absolutweb.de

# Public base URL of the app (used to build invite-email redirect links).
# Local dev: http://localhost:3000 — in production set your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E-Mail-Benachrichtigungen (optional; via Resend). Ohne diese Werte werden
# nur In-App-Benachrichtigungen (Glocke) erzeugt, keine E-Mails versendet.
# EMAIL_FROM muss eine in Resend verifizierte Absenderadresse sein.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=AWOS <no-reply@absolutweb.de>
